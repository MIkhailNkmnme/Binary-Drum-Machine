<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Zerkalius: Interleaving Genesis</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;700&display=swap');

        body { 
            background: #050505; color: #00ff66; 
            font-family: 'Consolas', monospace; 
            margin: 0; overflow: hidden; height: 100vh;
            position: relative;
        }

        /* ПАНЕЛЬ УПРАВЛЕНИЯ */
        .controls { 
            position: absolute; left: 0; top: 0;
            width: 320px; height: 100vh; z-index: 100;
            background: rgba(17, 17, 17, 0.95); 
            border-right: 2px solid #00ff66; 
            box-sizing: border-box;
            overflow-y: auto; transition: transform 0.3s ease;
        }
        .controls::-webkit-scrollbar { width: 5px; }
        .controls::-webkit-scrollbar-thumb { background: #333; }

        .control-group { background: #1a1a1a; padding: 6px 10px; border-bottom: 1px solid #222; }
        
        .player-buttons { display: flex; gap: 4px; margin-bottom: 5px; }
        .player-buttons button { font-size: 13px; border: none; cursor: pointer; border-radius: 3px; padding: 6px 4px; font-weight: bold; }
        #prevBtn, #nextBtn { flex: 1; background: #222; color: #fff; }
        #playBtn { flex: 3; background: #00ff66; color: #000; }
        #stopBtn { flex: 2; background: #ff3333; color: #fff; }

        .row-between { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2px; }
        label, .lbl { font-size: 11px; color: #aaa; font-family: sans-serif; cursor: pointer;}
        .val { color: #fff; font-family: monospace; font-size: 11px; }

        input[type="range"] { width: 100%; cursor: pointer; margin-bottom: 5px; height: 12px; }
        input[type="number"], input[type="text"] { background: #000; color: #fff; border: 1px solid #444; padding: 3px; border-radius: 2px; width: 45px; text-align: center; font-size: 11px;}
        select { background: #222; color: #fff; border: 1px solid #444; padding: 2px; border-radius: 3px; width: 100%; font-size: 11px; margin-bottom: 5px; }
        input[type="checkbox"] { pointer-events: auto; cursor: pointer; margin: 0 4px 0 0; }

        .color-row { display: flex; align-items: center; justify-content: space-between; gap: 5px; margin-bottom: 2px; }
        input[type="color"] { border: none; width: 20px; height: 15px; padding: 0; background: none; cursor: pointer; }

        textarea { 
            background: #000; color: #00ccff; border: 1px solid #444; 
            font-family: inherit; font-size: 11px; width: 100%; height: 40px; 
            border-radius: 3px; resize: none; padding: 4px; box-sizing: border-box;
            margin-bottom: 2px;
        }

        .btn-action { background: #333; color: #ffcc00; border: 1px solid #ffcc00; padding: 4px; border-radius: 3px; cursor: pointer; width: 100%; margin-bottom: 2px; font-size: 10px; font-weight: bold;}
        .btn-action:hover { background: #ffcc00; color: #000; }
        .btn-danger { color: #ff3333; border-color: #ff3333; }
        .btn-danger:hover { background: #ff3333; color: #fff; }

        /* ХОЛСТ */
        #screenContainer { 
            position: absolute; left: 0; top: 0;
            width: 100vw; height: 100vh; 
            background: #050505; overflow: hidden; 
            display: flex; align-items: center; justify-content: center; 
            z-index: 10;
        }
        canvas { display: block; cursor: pointer; }

        #hotkeyIndicator {
            position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%);
            background: rgba(0, 0, 0, 0.8); border: 1px solid #00ff66;
            color: #00ff66; font-size: 16px; font-weight: bold; padding: 6px 15px;
            border-radius: 5px; opacity: 0; transition: opacity 0.3s; pointer-events: none;
            z-index: 120;
        }

        /* ПЛАВАЮЩИЙ ИНСТРУМЕНТАРИЙ */
        .floating-toolbar {
            position: absolute; right: 10px; top: 10px; z-index: 100;
            display: flex; flex-direction: column; gap: 6px; align-items: flex-end;
            transition: transform 0.3s ease, opacity 0.3s ease;
        }
        .float-pill-btn {
            background: rgba(10, 10, 10, 0.85); border: 1px solid #444;
            color: #fff; padding: 6px 12px; border-radius: 4px; 
            cursor: pointer; font-family: monospace; font-size: 12px;
            display: flex; align-items: center; gap: 5px; box-shadow: 0 0 10px rgba(0,0,0,0.5);
            transition: background 0.2s, border-color 0.2s;
        }
        .float-pill-btn:hover { background: #222; border-color: #00ff66; }
        
        .float-circle-btn {
            background: rgba(10, 10, 10, 0.85); border: 1px solid #444;
            color: #00ccff; border-radius: 50%; width: 34px; height: 34px;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            font-size: 15px; box-shadow: 0 0 10px rgba(0,0,0,0.5);
            transition: background 0.2s, border-color 0.2s, color 0.2s;
        }
        .float-circle-btn:hover { background: #222; border-color: #00ccff; }
        .float-circle-btn.active {
            background: #00ccff; color: #000; border-color: #00ccff;
            box-shadow: 0 0 10px rgba(0, 204, 255, 0.5);
        }

        /* ЛОГ НАЙДЕННЫХ ПАТТЕРНОВ */
        .patterns-log-container {
            position: absolute; top: 10px; right: 120px; z-index: 90;
            background: rgba(10, 10, 10, 0.85); border: 1px solid #444;
            border-radius: 4px; padding: 8px; width: 220px; max-height: 350px;
            overflow-y: auto; transition: transform 0.3s ease, opacity 0.3s ease;
            box-shadow: 0 0 15px rgba(0,0,0,0.5);
        }
        .patterns-log-title {
            font-size: 10px; color: #888; margin-bottom: 5px;
            font-family: sans-serif; font-weight: bold; text-transform: uppercase;
        }
        .patterns-log-box {
            font-family: 'Consolas', monospace; font-size: 11px;
            color: #888; white-space: pre-wrap; word-break: break-all;
            max-height: 120px; overflow-y: auto;
        }

        /* РЕЖИМ ДЗЕН */
        body.zen-mode .controls { transform: translateX(-320px); }
        body.zen-mode .floating-toolbar { transform: translateX(150px); opacity: 0; pointer-events: none;}
        body.zen-mode .patterns-log-container { transform: translateX(350px); opacity: 0; pointer-events: none;}
    </style>
</head>
<body>

    <!-- ГЛОБАЛЬНЫЙ ПЕРЕХВАТ ОШИБОК ДЛЯ ВЫВОДА В ХОЛСТ -->
    <script>
        window.onerror = function(message, source, lineno, colno, error) {
            const canvas = document.getElementById('screenCanvas');
            if (canvas) {
                const ctx = canvas.getContext('2d');
                ctx.fillStyle = '#050505';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = '#ff3333';
                ctx.font = '13px monospace';
                ctx.textAlign = 'left';
                ctx.textBaseline = 'top';
                ctx.fillText("⚠️ КРИТИЧЕСКАЯ ОШИБКА ДВИЖКА (ВЫВЕДЕНО НА ХОЛСТ):", 20, 20);
                ctx.fillText(message, 20, 45);
                ctx.fillText("Файл: " + source + " | Строка: " + lineno + ":" + colno, 20, 65);
                if (error && error.stack) {
                    let lines = error.stack.split('\n');
                    for (let i = 0; i < Math.min(lines.length, 12); i++) {
                        ctx.fillText(lines[i], 20, 95 + i * 18);
                    }
                }
            }
            return false;
        };
    </script>

    <div class="controls">

        <div class="control-group">
            <button id="clearCanvasBtn" class="btn-action btn-danger" style="margin-bottom: 2px;">🧹 Очистить холст (Del)</button>
        </div>

        <!-- РЕЗЕРВНАЯ КОПИЯ -->
        <div class="control-group">
            <span class="lbl" style="color:#00ff66; font-weight:bold;">Zerkalius: Interleaving Genesis</span>
            <div style="display:flex; gap:4px; margin-top:3px;">
                <button id="exportCodeBtn" class="btn-action" style="flex:1;">Экспорт</button>
                <button id="importCodeBtn" class="btn-action" style="flex:1;">Импорт</button>
