    <script>
        // ВСПОМОГАТЕЛЬНЫЕ КРАШ-ПРОФ ХЕЛПЕРЫ В САМОМ НАЧАЛЕ ФАЙЛА (ГЛОБАЛЬНАЯ ОБЛАСТЬ)
        const hexToRgba = (hex, alpha) => {
            if (!hex || hex.length < 7) return `rgba(0, 0, 0, ${alpha})`;
            let r = parseInt(hex.slice(1, 3), 16);
            let g = parseInt(hex.slice(3, 5), 16);
            let b = parseInt(hex.slice(5, 7), 16);
            return `rgba(${r},${g},${b},${alpha})`;
        };

        const safeChecked = (id, fallback = false) => {
            const el = document.getElementById(id);
            return el ? el.checked : fallback;
        };

        const safeValue = (id, fallback = "") => {
            const el = document.getElementById(id);
            return el ? el.value : fallback;
        };

        const safeBind = (id, event, handler) => {
            const el = document.getElementById(id);
            if (el) el.addEventListener(event, handler);
        };

        const GCD = (a, b) => { while (b !== 0) { let temp = b; b = a % b; a = temp; } return a; };
        const LCM = (a, b) => { return (a === 0 || b === 0) ? 0 : (a / GCD(a, b)) * b; };

        const STATE = {
            lines: [],          
            globalStep: 0,
            maxCycle: 1,
            isPlaying: false,
            isReverse: false,
            lastTick: 0,
            rafId: null,
            foundPatterns: new Set(),
            flashes: new Map(), 
            interleavingLog: [], 
            
            offsetX: 0,
            offsetY: 0,
            isDragging: false,
            dragStartX: 0,
            dragStartY: 0,
            hasMoved: false
        };

        // ЛЕНИВЫЕ КРАШ-ПРОФ ГЕТТЕРЫ
        const UI = {
            get canvas() { return document.getElementById('screenCanvas'); },
            get ctx() { return this.canvas ? this.canvas.getContext('2d') : null; },
            get container() { return document.getElementById('screenContainer'); },
            get hotkeyInd() { return document.getElementById('hotkeyIndicator'); },
            get playBtn() { return document.getElementById('playBtn'); }
        };

        const PRESETS = {
            matrix: { c1: '#ffffff', c0: '#00ff66', bg: '#050505' },
            cyber: { c1: '#ffcc00', c0: '#00ccff', bg: '#0a0a1a' },
            blood: { c1: '#ffffff', c0: '#ff0000', bg: '#1a0000' },
            synthwave: { c1: '#00ffff', c0: '#ff00ff', bg: '#0f0515' },
            zerkalius: { c1: '#dcdcdc', c0: '#0066cc', bg: '#050a15' },
            crypto: { c1: '#ff3333', c0: '#555555', bg: '#000000' },
            bw: { c1: '#ffffff', c0: '#555555', bg: '#000000' }
        };

        function resetPositionWithHeightScale(scaleFactor) {
            const canvas = UI.canvas;
            const container = UI.container;
            if (!canvas || !container) return;

            canvas.width = container.clientWidth || window.innerWidth;
            canvas.height = container.clientHeight || window.innerHeight;

            STATE.offsetX = 0;
            STATE.offsetY = 0;
            if (STATE.lines.length > 0) {
                let canvasHeight = canvas.height;
                let lh = parseFloat(safeValue('lhSlider', 1.0));
                let screenRows = parseInt(safeValue('screenSlider', 64));
                let activeRowCount = Math.min(STATE.lines.length, screenRows);
                
                if (activeRowCount > 0) {
                    let padding = scaleFactor === 1.0 ? 60 : 20;
                    let optimalSize = Math.floor((canvasHeight * scaleFactor - padding) / (activeRowCount * lh));
                    optimalSize = Math.max(5, Math.min(100, optimalSize));
                    
                    const fontSlider = document.getElementById('fontSlider');
                    if (fontSlider) fontSlider.value = optimalSize;
                    const fontVal = document.getElementById('fontVal');
                    if (fontVal) fontVal.textContent = optimalSize + 'px';
                }
            }
            render();
            showNotification(scaleFactor === 1.0 ? "ЦЕНТР И АВТОМАСШТАБ (100%)" : "ЦЕНТР И МАСШТАБ (30%)");
        }

        let centerClickTimeout = null;
        safeBind('floatingCenterBtn', 'click', function(e) {
            if (centerClickTimeout) {
                clearTimeout(centerClickTimeout);
                centerClickTimeout = null;
                resetPositionWithHeightScale(0.3); 
            } else {
                centerClickTimeout = setTimeout(() => {
                    centerClickTimeout = null;
                    resetPositionWithHeightScale(1.0); 
                }, 220);
            }
        });

        function loadText(text) {
            const raw = text.split('\n').map(l => l.trim().replace(/\./g, '')).filter(l => l.length > 0);
            const nFact = parseInt(safeValue('nFactor', 2));
            
            STATE.maxCycle = 1;
            STATE.lines = raw.map((orig, index) => {
                let L = orig.length;
                let cN = (nFact === 0) ? L : nFact;
                let cycle = cN * L + 1;
                if (L > 0) STATE.maxCycle = LCM(STATE.maxCycle, cycle);
                
                let initiallyActive = (index === 0 || index === 1); 
                return { orig, L, cN, cycle, display: orig, isActive: initiallyActive, highlightMask: [] };
            });
            
            STATE.globalStep = 0;
            STATE.offsetX = 0;
            STATE.offsetY = 0;
            STATE.foundPatterns.clear();
            STATE.flashes.clear();
            STATE.interleavingLog = ["Инициализация базовой строки..."];
            updateFoundBox();
            
            const stepSlider = document.getElementById('stepSlider');
            if (stepSlider) {
                stepSlider.max = isFinite(STATE.maxCycle) && STATE.maxCycle < 100000 ? STATE.maxCycle : 100000;
            }
            updateLogic();
        }

        safeBind('sierpBtn', 'click', () => {
            let seed = safeValue('sierpSeed', '1').trim() || "1";
            let rows = parseInt(safeValue('sierpRows', 64)) || 64;
            
            let lines = [seed];
            for (let i = 1; i < rows; i++) {
                let prev = lines[i-1];
                let nextStr = "";
                let padded = "0" + prev + "0"; 
                for(let j=0; j < padded.length - 1; j++) {
                    let a = padded[j] === '1' ? 1 : 0;
                    let b = padded[j+1] === '1' ? 1 : 0;
                    nextStr += (a ^ b).toString(); 
                }
                lines.push(nextStr);
            }
            loadText(lines.join('\n'));
            showNotification("СЕРПИНСКИЙ ГОТОВ");
        });

        function updateFoundBox() {
            let arr = Array.from(STATE.foundPatterns);
            arr.sort((a, b) => a.length - b.length);
            const foundLog = document.getElementById('foundPatternsLog');
            if (foundLog) foundLog.textContent = arr.join('\n');
            const detailsLog = document.getElementById('interleavingLogDetails');
            if (detailsLog) detailsLog.textContent = STATE.interleavingLog.join('\n');
        }

        function calculateState(triggerSearch) {
            let newlyFound = false;
            let rawPatterns = safeValue('patternInput', '').split('\n').map(p => p.trim()).filter(p => p.length > 0);
            let applyFilter = safeChecked('filterCheck', false);
            let showHighlights = safeChecked('highlightCheck', true);
            let vbaActivation = safeChecked('activateOnPatternCheck', true);
            let useElka = safeChecked('elkaCheck', false);
            let useCylinder = safeChecked('cylinderCheck', false);
            let useInterleaving = safeChecked('interleavingCheck', true);

            let globalCleanText = "";
            let globalMap = [];

            // 1. Активация строк строго по индексу
            if (vbaActivation && STATE.foundPatterns.size > 0) {
                let rawPatternsLines = safeValue('patternInput', '').split('\n').map(p => p.trim());
                rawPatternsLines.forEach((pat, idx) => {
                    if (pat && idx < STATE.lines.length) {
                        if (STATE.foundPatterns.has(pat)) {
                            STATE.lines[idx].isActive = true;
                        }
                    }
                });
                if (STATE.lines.length > 0) {
                    STATE.lines[0].isActive = true; 
                    if (STATE.lines.length > 1) STATE.lines[1].isActive = true;
                }
            } else if (!vbaActivation) {
                STATE.lines.forEach(l => l.isActive = true);
            }

            // Накапливаем буфер для движения "Ёлка"
            let elkaBuffer = "";
            if (useElka) {
                elkaBuffer = STATE.lines.map(line => line.orig).join('');
                if (elkaBuffer.length > 0) {
                    let shift = Math.abs(STATE.globalStep) % elkaBuffer.length;
                    if (STATE.isReverse) {
                        elkaBuffer = elkaBuffer.slice(shift) + elkaBuffer.slice(0, shift);
                    } else {
                        elkaBuffer = elkaBuffer.slice(-shift) + elkaBuffer.slice(0, -shift);
                    }
                }
            }

            let elkaPtr = 0;

            // 2. Расчет сдвигов
            for (let i = 0; i < STATE.lines.length; i++) {
                let line = STATE.lines[i];
                if (line.L === 0) continue;

                let lineOrig = line.orig;
                if (useElka && elkaBuffer.length > 0) {
                    lineOrig = elkaBuffer.substring(elkaPtr, elkaPtr + line.L);
                    elkaPtr += line.L;
                }

                let currentStepValue = (vbaActivation && !line.isActive) ? 0 : Math.abs(STATE.globalStep);

                let s_display = currentStepValue % line.cycle;
                if (STATE.isReverse && line.isActive) {
                    s_display = line.cycle - s_display;
                    if (s_display === line.cycle) s_display = 0;
                }

                let cylShift = 0;
                if (useCylinder) {
                    cylShift = currentStepValue % line.L;
                }

                let res = "";
                let gridSize = line.L + s_display;
                if (line.cN * line.L > gridSize) {
                    gridSize = line.cN * line.L;
                }

                for (let p = 1; p <= gridSize; p++) {
                    let d_active = (p >= 1 + s_display && p <= line.L + s_display);
                    let t_active = (p >= line.L + 1 && p <= line.cN * line.L);

                    let d_char = "";
                    if (d_active) {
                        let idx = p - s_display - 1;
                        if (useCylinder) idx = (idx + cylShift) % line.L;
                        d_char = lineOrig[idx];
                    }

                    let t_char = "";
                    if (t_active) {
                        let t_idx = ((p - line.L - 1) % line.L);
                        if (useCylinder) t_idx = (t_idx + cylShift) % line.L;
                        t_char = lineOrig[t_idx];
                    }

                    if (d_active && t_active) {
                        res += (parseInt(d_char) ^ parseInt(t_char)).toString();
                    } else if (d_active) {
                        res += d_char;
                    } else if (t_active) {
                        res += t_char;
                    }
                }
                
                line.display = res;
                line.highlightMask = new Array(res.length).fill(false);

                if (!applyFilter || line.isActive) {
                    for (let c = 0; c < res.length; c++) {
                        globalCleanText += res[c];
                        globalMap.push({ r: i, c: c });
                    }
                }
            }

            // 3. Поиск паттернов
            if (triggerSearch && globalCleanText.length > 0) {
                let textToSearch = globalCleanText + globalCleanText;
                rawPatterns.forEach(pat => {
                    if (!STATE.foundPatterns.has(pat)) {
                        let pos = textToSearch.indexOf(pat);
                        if (pos !== -1 && pos < globalCleanText.length) {
                            STATE.foundPatterns.add(pat);
                            newlyFound = true;
                        }
                    }
                });
            }

            // 4. ОРГАНИЧЕСКИЙ ПОИСК ЧЕРЕЗ ИНТЕРЛИВИНГ
            if (useInterleaving && vbaActivation && STATE.lines.length > 1) {
                let lastActiveIdx = -1;
                for (let i = 0; i < STATE.lines.length; i++) {
                    if (STATE.lines[i].isActive) {
                        lastActiveIdx = i;
                    }
                }

                if (lastActiveIdx >= 1) {
                    let strAbove = STATE.lines[lastActiveIdx - 1].display;
                    let strCurrent = STATE.lines[lastActiveIdx].display;

                    let interleaved = "";
                    let maxL = Math.max(strAbove.length, strCurrent.length);
                    for (let j = 0; j < maxL; j++) {
                        if (j < strAbove.length) interleaved += strAbove[j];
                        if (j < strCurrent.length) interleaved += strCurrent[j];
                    }

                    let nextIdx = lastActiveIdx + 1;
                    if (nextIdx < STATE.lines.length) {
                        let nextPattern = STATE.lines[nextIdx].orig.replace(/\./g, '');
                        let ilSearchText = interleaved + interleaved;

                        let pos = ilSearchText.indexOf(nextPattern);
                        if (pos !== -1 && pos < interleaved.length) {
                            STATE.lines[nextIdx].isActive = true;
                            STATE.foundPatterns.add(nextPattern);
                            newlyFound = true;

                            STATE.interleavingLog.push(`Синтез строки ${nextIdx} [${nextPattern}] из пары ${lastActiveIdx-1} & ${lastActiveIdx}`);

                            for (let k = 0; k < nextPattern.length; k++) {
                                STATE.flashes.set(nextIdx + "_" + k, Date.now() + 1500);
                            }
                        }
                    }
                }
            }

            // 5. МАСКИРОВАНИЕ ПОДСВЕТКИ (ТОЛЬКО НА АКТИВНЫХ)
            if (showHighlights && globalCleanText.length > 0) {
                let textToSearch = globalCleanText + globalCleanText;
                rawPatterns.forEach(pat => {
                    let pos = textToSearch.indexOf(pat);
                    if (pos !== -1) { 
                        if (pos < globalCleanText.length) {
                            for (let k = 0; k < pat.length; k++) {
                                let loc = globalMap[(pos + k) % globalCleanText.length];
                                if (loc && STATE.lines[loc.r].isActive) { 
                                    STATE.lines[loc.r].highlightMask[loc.c] = true;
                                }
                            }
                        }
                    }
                });
            }

            return newlyFound;
        }

        function updateLogic() {
            let newlyFound = calculateState(true);
            
            if (newlyFound) {
                calculateState(false); 
                updateFoundBox();
                showNotification("🎯 НАЙДЕН НОВЫЙ ПАТТЕРН!");
            }

            const stepVal = document.getElementById('stepVal');
            if (stepVal) {
                stepVal.textContent = `${Math.abs(STATE.globalStep)} / ${isFinite(STATE.maxCycle) ? STATE.maxCycle : '∞'}`;
            }
            const stepSlider = document.getElementById('stepSlider');
            if (stepSlider && stepSlider.max > 0) {
                stepSlider.value = Math.abs(STATE.globalStep) % stepSlider.max;
            }
            
            render();
        }

        function render() {
            const canvas = UI.canvas;
            const container = UI.container;
            const ctx = UI.ctx;
            if (!canvas || !container || !ctx) return;

            canvas.width = container.clientWidth || window.innerWidth;
            canvas.height = container.clientHeight || window.innerHeight;

            const bgColor = safeValue('bgColor', '#050505');
            ctx.fillStyle = bgColor;
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // --- ЖИВАЯ ОТЛАДОЧНАЯ ПАНЕЛЬ С СИСТЕМНЫМИ ЛОГАМИ ---
            ctx.save();
            ctx.fillStyle = 'rgba(10, 10, 10, 0.45)';
            ctx.fillRect(20, 20, 280, 105);
            ctx.strokeStyle = '#00ff66';
            ctx.lineWidth = 1;
            ctx.strokeRect(20, 20, 280, 105);
            
            ctx.fillStyle = '#00ff66';
            ctx.font = '10px Roboto Mono, monospace';
            ctx.textAlign = 'left';
            ctx.textBaseline = 'top';
            ctx.fillText("📡 ZERKALIUS DIAGNOSTIC TERMINAL:", 30, 28);
            ctx.fillStyle = '#888';
            ctx.fillText("Кадр (Шаг): " + STATE.globalStep, 30, 45);
            ctx.fillText("Активных строк: " + STATE.lines.filter(l => l.isActive).length + " из " + STATE.lines.length, 30, 60);
            ctx.fillText("Направление: " + (STATE.isReverse ? "РЕВЕРС (Назад)" : "ВПЕРЕД"), 30, 75);
            ctx.fillStyle = '#ffcc00';
            ctx.fillText("Лог: " + (STATE.interleavingLog[STATE.interleavingLog.length - 1] || "Ожидание..."), 30, 95);
            ctx.restore();

            if (STATE.lines.length === 0) return;

            let fontSize = parseInt(safeValue('fontSlider', 16));
            let lh = parseFloat(safeValue('lhSlider', 1.0));
            let screenRows = parseInt(safeValue('screenSlider', 64));
            let fontName = safeValue('fontSelect', 'monospace');
            let isBold = safeChecked('boldCheck', false);
            let useRadar = safeChecked('radarCheck', false);
            let useNeon = safeChecked('neonCheck', false);
            let showFrame = safeChecked('frameCheck', true);

            ctx.font = `${isBold ? 'bold' : 'normal'} ${fontSize}px ${fontName}`;
            ctx.textBaseline = 'middle';
            
            let charWidth = ctx.measureText('0').width;
            let lineHeight = fontSize * lh;
            
            let startIndex = 0;
            let renderCount = STATE.lines.length;
            
            if (renderCount > screenRows) {
                startIndex = Math.max(0, STATE.lines.length - screenRows); 
                renderCount = screenRows;
            }

            let dirColors = safeChecked('dirColorsCheck', false);
            let c1, c0;
            if (dirColors) {
                if (!STATE.isReverse) {
                    c1 = hexToRgba(safeValue('color1_fwd', '#ffffff'), safeValue('alpha1', 1.0));
                    c0 = hexToRgba(safeValue('color0_fwd', '#00ff66'), safeValue('alpha0', 0.5));
                } else {
                    c1 = hexToRgba(safeValue('color1_rev', '#ff00ff'), safeValue('alpha1', 1.0));
                    c0 = hexToRgba(safeValue('color0_rev', '#00ffff'), safeValue('alpha0', 0.5));
                }
            } else {
                c1 = hexToRgba(safeValue('color1', '#ffffff'), safeValue('alpha1', 1.0));
                c0 = hexToRgba(safeValue('color0', '#00ff66'), safeValue('alpha0', 0.5));
            }

            const hlColor = safeValue('hlColorInput', '#ff3333'); 
            const frameColor = safeValue('frameColorInput', '#ff3333');

            let applyFilter = safeChecked('filterCheck', false);
            let showHighlights = safeChecked('highlightCheck', true);

            let maxActiveLen = 0;
            let activeLinesRendered = 0;
            let activeStartY = -1;

            if (useRadar) {
                // --- ТОПОЛОГИЧЕСКИЙ РАДАР ---
                let centerX = canvas.width / 2 + STATE.offsetX;
                let centerY = canvas.height / 2 + STATE.offsetY;

                for (let i = 0; i < renderCount; i++) {
                    let actualIndex = startIndex + i;
                    let lineData = STATE.lines[actualIndex];
                    let text = lineData.display;
                    if (!text) continue;

                    let r = (i + 1) * lineHeight; 
                    let angleStep = (Math.PI * 2) / text.length;

                    ctx.globalAlpha = (!lineData.isActive && applyFilter) ? 0.25 : 1.0;

                    for (let c = 0; c < text.length; c++) {
                        let char = text[c];
                        if (char === ' ') continue;

                        let isHl = showHighlights && lineData.isActive && lineData.highlightMask[c];
                        
                        let flashEnd = STATE.flashes.get(actualIndex + "_" + c);
                        let isFlashing = flashEnd && Date.now() < flashEnd;

                        if (isFlashing) {
                            ctx.fillStyle = '#ffcc00'; 
                            ctx.shadowBlur = 10;
                            ctx.shadowColor = '#ffcc00';
                        } else {
                            ctx.fillStyle = isHl ? hlColor : (char === '1' ? c1 : c0);
                            if (useNeon && (char === '1' || isHl)) {
                                ctx.shadowBlur = 8;
                                ctx.shadowColor = isHl ? hlColor : (char === '1' ? (dirColors ? safeValue('color1_fwd', '#ffffff') : safeValue('color1', '#ffffff')) : (dirColors ? safeValue('color0_fwd', '#00ff66') : safeValue('color0', '#00ff66')));
                            } else {
                                ctx.shadowBlur = 0;
                            }
                        }

                        let angle = c * angleStep - (Math.PI / 2);
                        let cx = centerX + Math.cos(angle) * r;
                        let cy = centerY + Math.sin(angle) * r;

                        ctx.save();
                        ctx.translate(cx, cy);
                        ctx.rotate(angle + Math.PI / 2);
                        ctx.textAlign = 'center';
                        ctx.fillText(char, 0, 0);
                        ctx.restore();
                    }
                }
                ctx.shadowBlur = 0; 
            } else {
                // --- КЛАССИЧЕСКИЙ ЦЕНТРИРОВАННЫЙ ВИД ---
                let totalHeight = renderCount * lineHeight;
                let startY = ((canvas.height - totalHeight) / 2) + STATE.offsetY;
                let baseX = (canvas.width / 2) + STATE.offsetX;

                for (let i = 0; i < renderCount; i++) {
                    let actualIndex = startIndex + i;
                    let lineData = STATE.lines[actualIndex];
                    let text = lineData.display;
                    if (!text) continue;

                    let y = startY + (i * lineHeight) + (lineHeight / 2);

                    if (lineData.isActive) {
                        activeLinesRendered++;
                        if (activeStartY === -1) activeStartY = y - lineHeight / 2;
                        if (text.length > maxActiveLen) maxActiveLen = text.length;
                    }

                    ctx.globalAlpha = (!lineData.isActive && applyFilter) ? 0.25 : 1.0;

                    let hasAnyFlash = false;
                    for (let c = 0; c < text.length; c++) {
                        if (STATE.flashes.has(actualIndex + "_" + c) && Date.now() < STATE.flashes.get(actualIndex + "_" + c)) {
                            hasAnyFlash = true;
                            break;
                        }
                    }

                    if (!useNeon && !showHighlights && !hasAnyFlash) {
                        ctx.textAlign = 'center';
                        ctx.fillStyle = c0;
                        ctx.fillText(text.replace(/1/g, ' '), baseX, y);
                        ctx.fillStyle = c1;
                        ctx.fillText(text.replace(/0/g, ' '), baseX, y);
                    } else {
                        ctx.textAlign = 'left';
                        let fullWidth = text.length * charWidth;
                        let currentX = baseX - (fullWidth / 2);

                        for (let c = 0; c < text.length; c++) {
                            let char = text[c];
                            if (char === ' ') continue;

                            let isHl = showHighlights && lineData.isActive && lineData.highlightMask[c];
                            
                            let flashEnd = STATE.flashes.get(actualIndex + "_" + c);
                            let isFlashing = flashEnd && Date.now() < flashEnd;

                            if (isFlashing) {
                                ctx.fillStyle = '#ffcc00';
                                ctx.shadowBlur = 10;
                                ctx.shadowColor = '#ffcc00';
                            } else {
                                ctx.fillStyle = isHl ? hlColor : (char === '1' ? c1 : c0);
                                if (useNeon && (char === '1' || isHl)) {
                                    ctx.shadowBlur = 8;
                                    ctx.shadowColor = isHl ? hlColor : (char === '1' ? (dirColors ? safeValue('color1_fwd', '#ffffff') : safeValue('color1', '#ffffff')) : (dirColors ? safeValue('color0_fwd', '#00ff66') : safeValue('color0', '#00ff66')));
                                } else {
                                    ctx.shadowBlur = 0;
                                }
                            }

                            ctx.fillText(char, currentX + (c * charWidth), y);
                        }
                    }
                }
                ctx.shadowBlur = 0; 

                // --- РАСШИРЯЮЩАЯСЯ РАМКА ---
                if (showFrame && maxActiveLen > 0 && activeLinesRendered > 0) {
                    let boxWidth = maxActiveLen * charWidth + 24; 
                    let boxHeight = activeLinesRendered * lineHeight + 12;
                    let bx = baseX - boxWidth / 2;
                    let by = activeStartY - 6;

                    ctx.save();
                    ctx.strokeStyle = frameColor; 
                    ctx.lineWidth = 1.5;
                    ctx.globalAlpha = 0.6;
                    ctx.shadowBlur = 8;
                    ctx.shadowColor = frameColor;
                    ctx.strokeRect(bx, by, boxWidth, boxHeight);
                    ctx.restore();
                }
            }
        }

        // --- ИМПОРТ / ЭКСПОРТ СОСТОЯНИЯ ---
        safeBind('exportCodeBtn', 'click', () => {
            let activeLinesIndices = [];
            STATE.lines.forEach((l, idx) => { if(l.isActive) activeLinesIndices.push(idx); });

            let snapshot = {
                step: STATE.globalStep,
                rows: STATE.lines.map(l => l.orig),
                active: activeLinesIndices,
                patterns: Array.from(STATE.foundPatterns),
                nFactor: parseInt(safeValue('nFactor', 2)),
                preset: safeValue('presetSelect', 'matrix'),
                speed: parseInt(safeValue('speedSlider', 950)),
                turbo: parseInt(safeValue('turboSlider', 1)),
                size: parseInt(safeValue('fontSlider', 16)),
                radar: safeChecked('radarCheck', false),
                elka: safeChecked('elkaCheck', false),
                cylinder: safeChecked('cylinderCheck', false)
            };

            let code = btoa(encodeURIComponent(JSON.stringify(snapshot)));
            const codeBox = document.getElementById('snapshotCodeBox');
            if (codeBox) codeBox.value = code;
            showNotification("КОД СКОПИРОВАН");
        });

        safeBind('importCodeBtn', 'click', () => {
            let code = safeValue('snapshotCodeBox', '').trim();
            if(!code) return alert("Пожалуйста, вставьте код в текстовое поле!");
            try {
                let snapshot = JSON.parse(decodeURIComponent(atob(code)));
                
                const setElVal = (id, val) => { const el = document.getElementById(id); if(el) el.value = val; };
                setElVal('nFactor', snapshot.nFactor || 2);
                const nFactorVal = document.getElementById('nFactorVal');
                if (nFactorVal) nFactorVal.textContent = snapshot.nFactor || 2;

                setElVal('presetSelect', snapshot.preset || 'matrix');
                setElVal('speedSlider', snapshot.speed || 950);
                setElVal('turboSlider', snapshot.turbo || 1);
                setElVal('fontSlider', snapshot.size || 16);

                const setElChk = (id, val) => { const el = document.getElementById(id); if(el) el.checked = !!val; };
                setElChk('radarCheck', snapshot.radar);
                setElChk('elkaCheck', snapshot.elka);
                setElChk('cylinderCheck', snapshot.cylinder);

                if(snapshot.rows && snapshot.rows.length > 0) {
                    loadText(snapshot.rows.join('\n'));
                }

                STATE.globalStep = snapshot.step || 0;
                STATE.foundPatterns = new Set(snapshot.patterns || []);
                
                if(snapshot.active) {
                    STATE.lines.forEach((l, idx) => {
                        l.isActive = snapshot.active.includes(idx);
                    });
                }

                let p = PRESETS[snapshot.preset || 'matrix']; 
                if (p) {
                    setElVal('color1', p.c1);
                    setElVal('color0', p.c0);
                    setElVal('bgColor', p.bg);
                }

                updateFoundBox();
                updateLogic();
                showNotification("СОСТОЯНИЕ ИМПОРТИРОВАНО");
            } catch(e) {
                alert("Ошибка декодирования снимка! Убедитесь, что код верный.");
            }
        });

        // --- ИГРОВОЙ ЦИКЛ ---
        function loop(timestamp) {
            if (!STATE.isPlaying) return;

            let speedMs = 1001 - parseInt(safeValue('speedSlider', 950)); 
            let turbo = parseInt(safeValue('turboSlider', 1)) || 1; 

            let delta = timestamp - STATE.lastTick;

            if (delta >= speedMs || speedMs <= 1) {
                STATE.lastTick = timestamp - (speedMs > 1 ? delta % speedMs : 0);
                STATE.globalStep += (STATE.isReverse ? -turbo : turbo);
                updateLogic();
            }

            STATE.rafId = requestAnimationFrame(loop);
        }

        function togglePlay() {
            STATE.isPlaying = !STATE.isPlaying;
            if (STATE.isPlaying) {
                UI.playBtn.innerHTML = '⏸ Pause';
                UI.playBtn.style.background = '#ff3333';
                STATE.lastTick = performance.now();
                loop(performance.now());
            } else {
                UI.playBtn.innerHTML = '▶ Play';
                UI.playBtn.style.background = '#00ff66';
                cancelAnimationFrame(STATE.rafId);
                updateLogic(); 
            }
        }

        function showNotification(text) {
            const ind = UI.hotkeyInd;
            if (!ind) return;
            ind.textContent = text;
            ind.style.opacity = 1;
            clearTimeout(STATE.notifTimeout);
            STATE.notifTimeout = setTimeout(() => ind.style.opacity = 0, 1000);
        }

        // --- ИНИЦИАЛИЗАЦИЯ И СВЯЗЫВАНИЕ UI ---
        safeBind('playBtn', 'click', () => { togglePlay(); showNotification(STATE.isPlaying ? "PLAY" : "PAUSE"); });
        
        safeBind('stopBtn', 'click', () => { 
            STATE.isPlaying = false; STATE.globalStep = 0; STATE.foundPatterns.clear(); STATE.flashes.clear();
            cancelAnimationFrame(STATE.rafId); UI.playBtn.innerHTML = '▶ Play'; UI.playBtn.style.background = '#00ff66'; 
            
            STATE.lines.forEach((line, idx) => {
                line.isActive = (idx === 0 || idx === 1);
            });

            updateFoundBox(); updateLogic(); showNotification("СБРОС"); 
        });
        
        safeBind('clearMemoryBtn', 'click', () => { 
            STATE.foundPatterns.clear(); STATE.flashes.clear();
            STATE.lines.forEach((line, idx) => {
                line.isActive = (idx === 0 || idx === 1);
            });
            updateFoundBox(); updateLogic(); showNotification("ПАМЯТЬ ОЧИЩЕНА"); 
        });

        safeBind('clearCanvasBtn', 'click', () => {
            STATE.lines = [];
            STATE.globalStep = 0;
            STATE.foundPatterns.clear();
            STATE.flashes.clear();
            STATE.interleavingLog = [];
            cancelAnimationFrame(STATE.rafId);
            UI.playBtn.innerHTML = '▶ Play';
            UI.playBtn.style.background = '#00ff66';
            STATE.isPlaying = false;
            updateFoundBox();
            render();
            showNotification("ХОЛСТ ОЧИЩЕН");
        });
        
        safeBind('prevBtn', 'click', () => { STATE.globalStep--; updateLogic(); });
        safeBind('nextBtn', 'click', () => { STATE.globalStep++; updateLogic(); });
        
        safeBind('reverseBtn', 'click', function() { 
            STATE.isReverse = !STATE.isReverse; 
            this.innerHTML = STATE.isReverse ? '🔃 Направление: Назад' : '🔃 Направление: Вперед';
            this.style.color = STATE.isReverse ? '#ff3333' : '#ffcc00';
            this.style.borderColor = STATE.isReverse ? '#ff3333' : '#ffcc00';
            showNotification(STATE.isReverse ? "РЕВЕРС" : "ВПЕРЕД");
        });

        safeBind('floatingRadarBtn', 'click', function() {
            let chk = document.getElementById('radarCheck');
            if (chk) {
                chk.checked = !chk.checked;
                if (chk.checked) this.classList.add('active'); else this.classList.remove('active');
            }
            render();
        });

        safeBind('toggleLogDetails', 'click', function() {
            let details = document.getElementById('interleavingLogDetails');
            if (details) {
                if (details.style.display === 'none') {
                    details.style.display = 'block';
                    this.textContent = 'СКРЫТЬ ▴';
                } else {
                    details.style.display = 'none';
                    this.textContent = 'ПОДРОБНЕЕ ▾';
                }
            }
        });

        safeBind('patternFileLoader', 'change', function(e) {
            const file = e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                let content = e.target.result;
                document.getElementById('patternInput').value = content;
                try {
                    localStorage.setItem('saved_patterns_content', content);
                } catch(err) { console.warn("localStorage is blocked."); }
                updateLogic();
                showNotification("ПАТТЕРНЫ ЗАГРУЖЕНЫ");
            };
            reader.readAsText(file);
        });

        safeBind('patternInput', 'input', function() {
            try {
                localStorage.setItem('saved_patterns_content', this.value);
            } catch(err) { console.warn("localStorage is blocked."); }
            updateLogic();
        });

        // ПУЛ СЛУШАТЕЛЕЙ СДВИГОВ И ИЗМЕНЕНИЙ ПОЛЗУНКОВ
        safeBind('turboSlider', 'input', function() { document.getElementById('turboVal').textContent = this.value; });
        safeBind('fontSlider', 'input', function() { document.getElementById('fontVal').textContent = this.value + 'px'; render(); });
        safeBind('screenSlider', 'input', function() { document.getElementById('screenVal').textContent = this.value; render(); });
        safeBind('lhSlider', 'input', function() { document.getElementById('lhVal').textContent = this.value; });
        safeBind('nFactor', 'input', function() { document.getElementById('nFactorVal').textContent = this.value; render(); });
        
        safeBind('presetSelect', 'change', function() { 
            let p = PRESETS[this.value]; 
            if (p) {
                document.getElementById('color1').value = p.c1; 
                document.getElementById('color0').value = p.c0; 
                document.getElementById('bgColor').value = p.bg; 
                render();
            }
        });

        safeBind('dirColorsCheck', 'change', function() {
            let stdColors = document.getElementById('standardColors');
            let dirColors = document.getElementById('directionColors');
            if (stdColors && dirColors) {
                if (this.checked) {
                    stdColors.style.display = 'none';
                    dirColors.style.display = 'block';
                } else {
                    stdColors.style.display = 'block';
                    dirColors.style.display = 'none';
                }
            }
            render();
        });

        ['color1', 'alpha1', 'color0', 'alpha0', 'bgColor', 'hlColorInput', 'frameColorInput', 'fontSelect', 'patternInput', 'nFactor', 'highlightCheck', 'filterCheck', 'activateOnPatternCheck', 'interleavingCheck', 'boldCheck', 'radarCheck', 'neonCheck', 'cylinderCheck', 'elkaCheck', 'frameCheck', 'color0_fwd', 'color1_fwd', 'color0_rev', 'color1_rev'].forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                el.addEventListener('input', () => { if(id==='patternInput') updateLogic(); else render(); });
                el.addEventListener('change', () => { updateLogic(); });
            }
        });

        // --- УПРАВЛЕНИЕ МЫШЬЮ И ПЕРЕТАСКИВАНИЕ ---
        window.addEventListener('load', () => {
            const canvas = UI.canvas;
            if (!canvas) return;

            canvas.addEventListener('mousedown', e => {
                STATE.isDragging = true;
                STATE.hasMoved = false; 
                STATE.dragStartX = e.clientX - STATE.offsetX;
                STATE.dragStartY = e.clientY - STATE.offsetY;
            });

            window.addEventListener('mousemove', e => {
                if (STATE.isDragging) {
                    STATE.offsetX = e.clientX - STATE.dragStartX;
                    STATE.offsetY = e.clientY - STATE.dragStartY;
                    STATE.hasMoved = true; 
                    if (!STATE.isPlaying) render();
                }
            });

            window.addEventListener('mouseup', e => {
                STATE.isDragging = false;
            });

            // Кастомный единственный таймер клика
            let clickTimeout = null;
            canvas.addEventListener('click', e => {
                if (STATE.hasMoved) return;
                if (clickTimeout) {
                    clearTimeout(clickTimeout);
                    clickTimeout = null;
                    document.body.classList.toggle('zen-mode');
                    render();
                } else {
                    clickTimeout = setTimeout(() => {
                        clickTimeout = null;
                        togglePlay();
                    }, 220); 
                }
            });

            canvas.addEventListener('wheel', e => {
                e.preventDefault();
                let fontSl = document.getElementById('fontSlider');
                let size = parseInt(fontSl.value) + (e.deltaY > 0 ? -2 : 2);
                size = Math.max(5, Math.min(100, size));
                fontSl.value = size;
                document.getElementById('fontVal').textContent = size + 'px';
                render();
            });
        });

        // Вставка Ctrl+V
        document.addEventListener('paste', e => {
            let activeTag = (document.activeElement && document.activeElement.tagName) ? document.activeElement.tagName.toLowerCase() : '';
            if (activeTag === 'input' || activeTag === 'textarea' || activeTag === 'select') return; 
            let text = e.clipboardData.getData('text/plain');
            if (text) { loadText(text); showNotification("ТЕКСТ ВСТАВЛЕН"); }
        });

        document.addEventListener('keydown', e => {
            if (document.activeElement.tagName === 'TEXTAREA' || document.activeElement.tagName === 'INPUT') return;
            let turbo = parseInt(safeValue('turboSlider', 1)) || 1;
            if (e.code === 'ArrowRight') { e.preventDefault(); STATE.globalStep += turbo; updateLogic(); }
            if (e.code === 'ArrowLeft') { e.preventDefault(); STATE.globalStep -= turbo; updateLogic(); }
            if (e.code === 'Space') { e.preventDefault(); togglePlay(); }
            if (e.code === 'Delete') { e.preventDefault(); document.getElementById('clearCanvasBtn').click(); }
        });

        window.addEventListener('resize', render);

        // ПОЛНОСТЬЮ ПАССИВНЫЙ СТАРТ
        window.onload = function() {
            try {
                let savedPatterns = localStorage.getItem('saved_patterns_content');
                if (savedPatterns) {
                    document.getElementById('patternInput').value = savedPatterns;
                }
            } catch(e) { console.warn("localStorage is not available."); }
            
            const canvas = UI.canvas;
            const container = UI.container;
            if (canvas && container) {
                canvas.width = container.clientWidth || window.innerWidth;
                canvas.height = container.clientHeight || window.innerHeight;
                render();
            }
        };
    </script>
</body>
</html>
